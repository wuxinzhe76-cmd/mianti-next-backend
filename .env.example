# DigitalOcean 服务器配置
DO_DROPLET_IP=your_droplet_ip
DO_SSH_USER=root
DO_SSH_PORT=22
DO_SSH_KEY=your_ssh_private_key

# 数据库配置（生产环境）
DB_URL=jdbc:mysql://your_db_host:3306/mianti_prod
DB_USERNAME=root
DB_PASSWORD=your_db_password

# Redis 配置（生产环境）
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# 阿里云 DashScope API
DASHSCOPE_API_KEY=your_api_key

# Sentry 错误监控
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=production

# Nacos 配置中心
NACOS_SERVER=your_nacos_server:8848
NACOS_ENABLED=true

# Elasticsearch
ELASTICSEARCH_URI=http://your_es_host:9200

# 微信开放平台
WX_APP_ID=your_wx_app_id
WX_APP_SECRET=your_wx_app_secret

# 服务器端口
SERVER_PORT=8101

# etcd 服务
ETCD_SERVER=http://your_etcd_host:2379
